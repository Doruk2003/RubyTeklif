            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Aciklama</label>
              <textarea class="form-control" name="description" rows="2"></textarea>
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Doviz</label>
              <select class="form-select" name="currency_id">
                <% Array(@currencies).each_with_index do |currency, idx| %>
                  <% selected = idx.zero? %>
                  <option value="<%= currency["id"].to_s %>" <%= "selected" if selected %>>
                    <%= [currency["code"].to_s, currency["name"].to_s].reject(&:blank?).join(" - ") %>
                  </option>
                <% end %>
              </select>
            </div>

            <div class="mb-0">
              <label class="form-label fw-semibold">Kdv</label>
              <select class="form-select" name="has_vat">
                <option value="true" selected>VAR</option>
                <option value="false">YOK</option>
              </select>
            </div>
