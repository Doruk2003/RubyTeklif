<%
  format_amount = lambda do |value|
    number_with_precision(value.to_d, precision: 2, delimiter: ".", separator: ",")
  end

  format_date = lambda do |value|
    raw = value.to_s
    next "-" if raw.blank?
    begin
      Date.parse(raw).strftime("%d.%m.%Y")
    rescue StandardError
      raw
    end
  end

  currency_for = lambda do |item|
    symbol = item.dig("products", "currencies", "symbol").to_s.presence
    code = item.dig("products", "currencies", "code").to_s.upcase.presence
    symbol.presence || code.presence || "TRY"
  end

  format_money = lambda do |value, unit|
    "#{format_amount.call(value)} #{unit}".strip
  end

  normalize_rate = lambda do |item, code|
    c = code.to_s.upcase
    next BigDecimal("1") if %w[TRY TL].include?(c)
    raw_rate = item.dig("products", "currencies", "rate_to_try").to_d
    raw_rate.positive? ? raw_rate : BigDecimal("1")
  end

  all_items = Array(@offer&.dig("offer_items")).compact
  expense_item = lambda { |item| item&.dig("description").to_s.strip.upcase.start_with?("[EXTRA MASRAF]") }
  sorted_items = all_items.sort_by { |item| expense_item.call(item) ? 1 : 0 }

  discount_totals_by_currency = Hash.new { |h, k| h[k] = BigDecimal("0") }
  sorted_items.each do |item|
    qty = item["quantity"].to_d
    unit_price = item["unit_price"].to_d
    discount_rate = item["discount_rate"].to_d
    discount_amount = (qty * unit_price) * discount_rate / 100
    unit = currency_for.call(item)
    discount_totals_by_currency[unit] += discount_amount
  end

  item_units = sorted_items.map { |item| currency_for.call(item) }.uniq
  total_unit_label = item_units.size > 1 ? "TL" : item_units.first.to_s.presence || "TRY"
  discount_label = if discount_totals_by_currency.empty?
                     "-"
                   else
                     discount_totals_by_currency.map { |unit, amount| format_money.call(amount, unit) }.join(" | ")
                   end

  rate_map = {}
  symbol_map = {}
  sorted_items.each do |item|
    code = item.dig("products", "currencies", "code").to_s.upcase.presence || "TRY"
    symbol = item.dig("products", "currencies", "symbol").to_s.presence || code
    rate_map[code] ||= normalize_rate.call(item, code)
    symbol_map[code] ||= symbol
  end

  gross_try_total = sorted_items.sum do |item|
    code = item.dig("products", "currencies", "code").to_s.upcase.presence || "TRY"
    rate = rate_map[code] || BigDecimal("1")
    line_total = item["line_total"].to_d
    vat_amount = line_total * item.dig("products", "vat_rate").to_d / 100
    (line_total + vat_amount) * rate
  end

  totals_priority = { "TRY" => 0, "TL" => 0, "USD" => 1, "EUR" => 2 }
  summary_totals = rate_map.keys.map do |code|
    rate = rate_map[code]
    amount = rate.positive? ? (gross_try_total / rate) : BigDecimal("0")
    {
      code: code,
      symbol: symbol_map[code].to_s.presence || code,
      amount: amount
    }
  end.sort_by { |row| [totals_priority.fetch(row[:code].to_s.upcase, 99), row[:code].to_s] }

  if summary_totals.empty? && @offer.present?
    summary_totals = [{ code: "TRY", symbol: "TL", amount: @offer["gross_total"].to_d }]
  end
%>

<div class="row g-3">
  <div class="col-12">
    <div class="card shadow-sm app-header-card">
      <div class="card-body d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3">
        <div>
          <h1 class="h4 mb-1 text-white">Teklif Detayı</h1>
          <p class="text-secondary mb-0">Teklif #<%= @offer&.dig("offer_number").to_s.presence || "-" %></p>
        </div>
        <div class="d-flex flex-wrap align-items-center gap-2 app-header-actions">
          <%= list_nav_button(offers_standart_index_path, class_name: "app-header-icon-btn", label: "Listeye Dön") %>
          <% if @offer.present? %>
            <% if @offer["deleted_at"].present? %>
              <%= link_to restore_offers_standart_path(@offer["id"]),
                    data: { turbo_method: :patch, turbo_confirm: "Geri yüklensin mi?", tip: "Geri Yükle" },
                    class: "btn app-header-icon-btn d-inline-flex align-items-center justify-content-center",
                    aria: { label: "Geri Yükle" } do %>
                <span class="material-symbols-outlined">restore_from_trash</span>
              <% end %>
            <% else %>
              <%= link_to offers_standart_path(@offer["id"]),
                    data: { turbo_method: :delete, turbo_confirm: "Arşivlensin mi?", tip: "Arşivle" },
                    class: "btn app-header-icon-btn d-inline-flex align-items-center justify-content-center",
                    aria: { label: "Arşivle" } do %>
                <span class="material-symbols-outlined">archive</span>
              <% end %>
            <% end %>
          <% end %>
          <%= home_nav_button(home_path, class_name: "app-header-icon-btn", icon: "home") %>
        </div>
      </div>
    </div>
  </div>

  <% if @offer.present? %>
    <div class="col-12">
      <div class="card shadow-sm">
        <div class="card-header bg-white border-bottom pt-4 px-4 pb-3">
          <h6 class="fw-bold text-secondary mb-0 d-flex align-items-center gap-2">
            <span class="material-symbols-outlined fs-5">info</span>
            Genel Bilgiler
          </h6>
        </div>
        <div class="card-body p-4">
          <div class="row g-4">
            <div class="col-6 col-md-3">
              <div class="small text-secondary text-uppercase fw-bold mb-1" style="font-size: 0.7rem; letter-spacing: 0.05em;">Proje</div>
              <div class="text-dark fw-semibold"><%= @offer["project"].to_s.presence || "-" %></div>
            </div>
            <div class="col-6 col-md-3">
              <div class="small text-secondary text-uppercase fw-bold mb-1" style="font-size: 0.7rem; letter-spacing: 0.05em;">Teklif Türü</div>
              <div class="text-dark">
                <% type = @offer["offer_type"].to_s.downcase %>
                <% case type
                   when "standart", "standard" %>
                  <span class="badge bg-light text-dark border">Standart</span>
                <% when "demonte" %>
                  <span class="badge bg-light text-primary border">Demonte</span>
                <% when "montaj" %>
                  <span class="badge bg-light text-success border">Montaj</span>
                <% else %>
                  <span class="badge bg-light text-secondary border"><%= type.capitalize %></span>
                <% end %>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="small text-secondary text-uppercase fw-bold mb-1" style="font-size: 0.7rem; letter-spacing: 0.05em;">Durum</div>
              <div class="text-dark">
                <% status = @offer["status"].to_s.downcase %>
                <% if %w[surec_isliyor taslak beklemede].include?(status) %>
                  <span class="badge bg-primary text-white border-0 px-2 rounded-pill">SÜREÇ İŞLİYOR</span>
                <% elsif status == "onaylandi" %>
                  <span class="badge bg-success text-white border-0 px-2 rounded-pill">ONAYLANDI</span>
                <% elsif status == "reddedildi" %>
                  <span class="badge bg-danger text-white border-0 px-2 rounded-pill">RED EDİLDİ</span>
                <% else %>
                  <span class="badge bg-info-subtle text-info border-0 px-2 rounded-pill"><%= status.upcase %></span>
                <% end %>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="small text-secondary text-uppercase fw-bold mb-1" style="font-size: 0.7rem; letter-spacing: 0.05em;">Toplam Tutar</div>
              <% summary_totals.each do |row| %>
                <div class="h6 fw-bold text-primary mb-0"><%= format_money.call(row[:amount], row[:symbol]) %></div>
              <% end %>
              <div class="small text-muted mt-1">İskonto: <%= discount_label %></div>
            </div>
            <div class="col-6 col-md-3">
              <div class="small text-secondary text-uppercase fw-bold mb-1" style="font-size: 0.7rem; letter-spacing: 0.05em;">Müşteri</div>
              <div class="text-dark"><%= @offer.dig("companies", "name").to_s.presence || "-" %></div>
            </div>
            <div class="col-6 col-md-3">
              <div class="small text-secondary text-uppercase fw-bold mb-1" style="font-size: 0.7rem; letter-spacing: 0.05em;">Tarih</div>
              <div class="text-dark"><%= format_date.call(@offer["offer_date"]) %></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card shadow-sm overflow-hidden">
        <div class="card-header bg-white border-bottom pt-4 px-4 pb-3">
          <h6 class="fw-bold text-secondary mb-0 d-flex align-items-center gap-2">
            <span class="material-symbols-outlined fs-5">list_alt</span>
            Teklif Kalemleri
          </h6>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 rt-table">
              <thead>
                <tr>
                  <th class="ps-4">Ürün / Hizmet</th>
                  <th class="text-end">Miktar</th>
                  <th class="text-end">Birim Fiyat</th>
                  <th class="text-end">İskonto %</th>
                  <th class="text-end">Döviz</th>
                  <th class="text-end pe-4">Toplam</th>
                </tr>
              </thead>
              <tbody>
                <% sorted_items.each do |item| %>
                  <% currency = currency_for.call(item) %>
                  <% description_text = item["description"].to_s %>
                  <% is_expense = expense_item.call(item) %>
                  <% product_name = item.dig("products", "name").to_s.presence || description_text %>
                  <% category_name = item.dig("products", "categories", "name").to_s.presence %>
                  <% extra_line_1, extra_line_2 = if is_expense
                       left, right = description_text.split(" | Birim:", 2)
                       [left.to_s, right.present? ? "Birim:#{right}" : nil]
                     else
                       [nil, nil]
                     end %>
                  <tr>
                    <td class="ps-4">
                      <% if is_expense %>
                        <div class="fw-semibold text-danger"><%= extra_line_1 %></div>
                        <% if extra_line_2.present? %>
                          <div class="small text-danger"><%= extra_line_2 %></div>
                        <% end %>
                      <% else %>
                        <div class="fw-semibold text-dark"><%= product_name.upcase %></div>
                        <div class="small text-muted">
                          <% if category_name.present? %>
                            <span class="fw-semibold">Kategori:</span> <%= category_name %> <span class="mx-1">|</span>
                          <% end %>
                          <span class="fw-semibold">Açıklama:</span> <%= description_text.presence || "-" %>
                        </div>
                      <% end %>
                    </td>
                    <td class="text-end"><%= format_amount.call(item["quantity"]) %></td>
                    <td class="text-end"><%= format_money.call(item["unit_price"], currency) %></td>
                    <td class="text-end text-danger"><%= number_with_precision(item["discount_rate"].to_d, precision: 2, delimiter: ".", separator: ",") %>%</td>
                    <td class="text-end"><%= currency %></td>
                    <td class="text-end pe-4 fw-bold"><%= format_money.call(item["line_total"], currency) %></td>
                  </tr>
                <% end %>

                <% if sorted_items.empty? %>
                  <tr>
                    <td colspan="6" class="text-center py-5 text-secondary fst-italic">Teklif kalemi bulunmuyor.</td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="col-12">
      <div class="card shadow-sm p-5 text-center">
        <span class="material-symbols-outlined fs-1 text-muted mb-3">error</span>
        <h4 class="fw-bold text-dark">Teklif bulunamadı</h4>
        <p class="text-secondary">Ulaşmaya çalıştığınız teklif kaydı mevcut değil.</p>
        <div class="mt-4">
          <%= link_to "Teklif Listesine Dön", offers_standart_index_path, class: "btn btn-dark px-4" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
